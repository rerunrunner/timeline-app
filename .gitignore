# Data and local config (data lives in per-project repo, e.g. runner-data)
editor/backend-java/data/
# Wrong path (../../runner-data) creates this; use ../../../runner-data to point at sibling repo
runner-data/

# Viewer data dir: populated at build time from data repo; do not commit JSON
viewer/src/data/*.json
# Packaged dataset for static build (generated by npm run fetch-data / build:static)
viewer/public/dataset.json

# OS
.DS_Store
